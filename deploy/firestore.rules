rules_version = '2';

// claude-master クラウド同期 Firestore セキュリティルール（v2）。
//
// クライアント SDK（ブラウザ）が触れる範囲を定義する。PC 側 agent /
// Cloud Run relay は **サーバ SDK（SA/ADC）＝rules 非対象**なので、
// ここでの deny はネイティブ同期（PushStatus/WatchWake/wake 書込等）
// に一切影響しない。
//
// ブラウザの identity は relay が cookie 認証（Google ログイン＋
// ALLOWED_EMAILS）済みオーナーへ発行する custom token（uid=cm-owner）
// のみ（サインインプロバイダは未有効化＝他経路でトークンは作れない）。
// 用途は「セッション status の snapshot listener（更新 push）」だけ
// なので read-only。wake はブラウザからは書かない（/ws 接続時に relay
// がサーバ側で書く）。
service cloud.firestore {
  match /databases/{database}/documents {

    // セッション状態（source PC が PushStatus で upsert・ブラウザは
    // onSnapshot で更新 push を受けるのみ）
    match /pcs/{pc}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == "cm-owner";
      allow write: if false;
    }

    // wake / pairings / commands 等その他は全てクライアント不可
    // （サーバ SDK 専用）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
